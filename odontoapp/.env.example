# Banco de dados (Neon ou Supabase)
DATABASE_URL="postgresql://user:password@host:5432/odontoapp?sslmode=require"

# NextAuth — gere com: openssl rand -base64 32
AUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# WhatsApp Cloud API (opcional — sem isso, usa link wa.me como fallback)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
# App Secret da Meta — usado para validar a assinatura X-Hub-Signature-256 do webhook.
# Se vazio, a verificação é pulada (apenas para desenvolvimento).
WHATSAPP_APP_SECRET=""

# Fuso horário das clínicas para cálculo de disponibilidade (default: America/Sao_Paulo)
CLINIC_TIMEZONE="America/Sao_Paulo"

# Segredo do cron de lembretes — o Vercel Cron envia "Authorization: Bearer <CRON_SECRET>".
# Gere com: openssl rand -base64 32
CRON_SECRET=""

# IA — agente de chat na página pública (Claude / Anthropic).
# Sem a chave, o widget degrada para respostas baseadas na base de conhecimento.
ANTHROPIC_API_KEY=""
# Modelo usado pelo agente (default: claude-opus-4-8). Para reduzir custo/latência: claude-haiku-4-5
AI_MODEL="claude-opus-4-8"
OPENAI_API_KEY=""

# Upload de imagens (opcional — ex: Cloudinary, Vercel Blob)
BLOB_READ_WRITE_TOKEN=""
