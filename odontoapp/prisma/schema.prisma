generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Tenant (Clínica) ───────────────────────────────────────────────────────

model Clinic {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  logo        String?
  description String?
  address     String?
  phone       String?
  whatsapp    String?
  email       String?

  // Horário de funcionamento (JSON: { mon: ["08:00","18:00"], ... } ou null para fechado)
  businessHours Json?

  // Redes sociais
  instagram String?
  facebook  String?
  website   String?

  // Configurações visuais
  primaryColor   String  @default("#0ea5e9")
  secondaryColor String  @default("#0369a1")

  // Plano de assinatura: basico | pro | premium
  plan String @default("basico")

  // Assinatura (Mercado Pago)
  subscriptionStatus    String    @default("none") // none | pending | authorized | paused | cancelled
  mpPreapprovalId       String?
  subscriptionUpdatedAt DateTime?

  // WhatsApp Cloud API (por tenant)
  waToken           String?
  waPhoneNumberId   String?
  waBusinessAccount String?

  // Buffer entre consultas (minutos)
  appointmentBuffer Int @default(15)

  // Antecedência mínima para cancelamento (horas)
  cancelMinHours Int @default(24)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  professionals Professional[]
  services      Service[]
  appointments  Appointment[]
  portfolioItems PortfolioItem[]
  knowledgeBase  KnowledgeBase[]

  @@map("clinics")
}

// ─── Usuários / Auth ─────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  admin_clinica
  recepcao
  dentista
}

model User {
  id       String   @id @default(cuid())
  clinicId String?
  clinic   Clinic?  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name          String
  email         String   @unique
  emailVerified DateTime?
  password      String?
  role          UserRole @default(recepcao)
  image         String?
  active        Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("users")
}

// NextAuth adapter tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Profissionais ────────────────────────────────────────────────────────────

model Professional {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name        String
  specialty   String?
  photo       String?
  bio         String?
  active      Boolean @default(true)

  // Horários de atendimento (JSON: { mon: ["08:00","17:00"], ... })
  workingHours Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@map("professionals")
}

// ─── Serviços ─────────────────────────────────────────────────────────────────

model Service {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  name        String
  description String?
  durationMin Int     // duração em minutos
  price       Decimal? @db.Decimal(10, 2)
  category    String?
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@map("services")
}

// ─── Agendamentos ─────────────────────────────────────────────────────────────

enum AppointmentStatus {
  solicitado
  confirmado
  cancelado
  concluido
  nao_compareceu
}

model Appointment {
  id           String @id @default(cuid())
  clinicId     String
  clinic       Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  professionalId String
  professional   Professional @relation(fields: [professionalId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  // Dados do paciente
  patientName  String
  patientPhone String
  patientEmail String?

  scheduledAt DateTime
  endsAt      DateTime

  status      AppointmentStatus @default(solicitado)
  notes       String?

  // Rastreio de notificações
  reminderSent24h Boolean @default(false)
  reminderSent1h  Boolean @default(false)

  // Consentimento LGPD
  lgpdConsent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

// ─── Portfólio ────────────────────────────────────────────────────────────────

model PortfolioItem {
  id          String  @id @default(cuid())
  clinicId    String
  clinic      Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  title       String
  description String?
  imageBefore String?
  imageAfter  String?
  category    String?
  order       Int     @default(0)
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolio_items")
}

// ─── Base de Conhecimento (Agente de IA) ──────────────────────────────────────

model KnowledgeBase {
  id       String @id @default(cuid())
  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  question String
  answer   String
  category String?
  active   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("knowledge_base")
}
